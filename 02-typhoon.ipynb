   "source": [
    "URL = (\"https://www.data.jma.go.jp/yoho/typhoon/\"\n",
    "       \"statistics/landing/landing.html\")\n",
    "\n",
    "r = requests.get(URL)\n",
    "r.encoding = \"utf-8\"\n",
    "tables = pd.read_html(io.StringIO(r.text))\n",
    "tbl = max(tables, key=lambda x: x.shape[0])"
   ]
